APP_NAME=Velora AI Automation Framework
APP_ENV=development
APP_PORT=8080
DATABASE_URL=postgres://postgres:postgres@db:5432/velora?sslmode=disable
REDIS_URL=redis:6379
JWT_SECRET=replace-with-a-super-secret-key
JWT_REFRESH_SECRET=replace-with-another-super-secret-key
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_API_URL=https://generativelanguage.googleapis.com
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW=1m
